# =============================================================================
# Kolmogorov's team — Systematic Equity Pipeline
# Environment Variables Template
# Copy this file to .env.dev and fill in your credentials.
# =============================================================================

# --- MinIO (Object Storage) ---
MINIO_USER=ift_bigdata
MINIO_PASSWORD=minio_password
MINIO_URL=http://localhost:9000

# --- PostgreSQL ---
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_DEV=localhost
POSTGRES_PORT_DEV=5439
POSTGRES_HOST_DOCKER=localhost
POSTGRES_PORT_DOCKER=5439
POSTGRES_DATABASE=fift

# --- MongoDB ---
MONGO_HOST=localhost
MONGO_PORT=27019
MONGO_USERNAME=ift_bigdata
MONGO_PASSWORD=mongo_password

# --- Apache Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Refinitiv / LSEG Data Platform (ESG scores — optional) ---
# Credentials from your LSEG/Refinitiv account (platform session via REST API).
REFINITIV_USERNAME=your_email@example.com
REFINITIV_PASSWORD=your_refinitiv_password
REFINITIV_APP_KEY=your_refinitiv_app_key_here

# --- NewsAPI (secondary news source — gap-fill when yfinance returns 0) ---
# Free tier: 100 requests/day. Get your key at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here
