# CACHE & TEMPORARY DIRECTORIES
═════════════════════════════════════════════════════════════════════════════
cache/
temp/
tmp/
logs/

# DOCUMENTATION BUILD OUTPUT
═════════════════════════════════════════════════════════════════════════════
docs/_build/
docs/.doctrees/
docs/generated/
site/

# DATABASE & STORAGE (local development only)
═════════════════════════════════════════════════════════════════════════════
postgres-data/
mongodb-data/
minio_data/
.minio.sys/
*.db
*.sqlite
*.sqlite3

# POETRY LOCK FILE (optional - include if managing dependencies)
═════════════════════════════════════════════════════════════════════════════
# poetry.lock  ← uncomment to exclude lock file, or leave commented to include

# CI/CD SECRETS
═════════════════════════════════════════════════════════════════════════════
.github/workflows/.env
.github/secrets/*
