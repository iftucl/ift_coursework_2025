# conf.yaml.example — Team Pearson current default configuration

pipeline:
  frequency: daily
  backfill_years: 5
  company_limit: 20
  enabled_extractors:
    - source_a
    - source_b
    - market_factors

universe:
  country_allowlist: null    # Optional filter on top of systematic_equity.company_static

logging:
  run_log_path: logs/pipeline_runs.jsonl

redis:
  host: localhost
  port: 6380
  db: 0
  required: false
  socket_timeout: 2
  connect_timeout: 2
  healthcheck_interval: 30

minio:
  endpoint: localhost:9000
  access_key: ift_bigdata
  secret_key: minio_password
  bucket: csreport
  secure: false

finnhub:
  rate_per_minute: 55
  max_history_years: 2

edgar:
  rate_per_second: 8
  pit_fallback_days: 45

market_factors:
  beta_window_days: 252
  benchmark_ticker: "SPY"    # Benchmark ETF series only; company universe comes from company_static

source_a:
  primary_source: yfinance
  enable_yfinance_fallback: true
  use_cache: true

source_b:
  strict_time: false
  av_cutoff_date: "2026-03-01"

alpha_vantage:
  api_key_env: ALPHA_VANTAGE_API_KEY
  throttle_seconds: 1.0
  max_retries: 3
  retry_backoff_seconds: 5.0

symbol_filter:
  skip_suffix_symbols: true
  symbol_regex_allow: "^[A-Z0-9]+$"

routing:
  av_only_if_regex: "^[A-Z0-9]+$"
  yf_for_suffixes: [".L", ".TO", ".PA", ".DE"]
  history_ticker_policy: "skip"
  history_blocklist: ["ABC", "ADS", "FB", "ATVI", "ABMD", "CELG"]

mongo:
  host: localhost
  port: 27019
  database: ift_cw
